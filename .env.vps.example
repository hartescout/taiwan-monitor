# Pharos VPS — OpenClaw agent environment
# Copy to .env.vps and fill in real values on the VPS.

# ── Connection ────────────────────────────────────────────
# SSH host / IP for the VPS running the OpenClaw agent
VPS_HOST="your-vps-ip-or-hostname"
VPS_USER="pharos"
VPS_SSH_KEY_PATH="~/.ssh/id_pharos_vps"

# ── Pharos API ────────────────────────────────────────────
# Production admin API the agent writes to
PHAROS_API_BASE_URL="https://www.taiwan-monitor.com/api/v1/admin"
PHAROS_ADMIN_API_KEY="your-admin-api-key"
PHAROS_CONFLICT_ID="iran-2026"

# ── Claude (OpenClaw agent) ───────────────────────────────
# OAuth token for the Claude agent running on the VPS
CLAUDE_OAUTH_TOKEN="your-claude-oauth-token"
