{
  "name": "pharos-ai",
  "version": "0.1.0",
  "license": "AGPL-3.0-only",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/Juliusolsson05/pharos-ai.git"
  },
  "homepage": "https://conflicts.app",
  "bugs": "https://github.com/Juliusolsson05/pharos-ai/issues",
  "author": "Julius Olsson",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:push:migration": "DATABASE_URL=\"$DATABASE_URL_MIGRATION\" prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "DATABASE_URL=\"$DATABASE_URL_MIGRATION\" prisma migrate deploy",
    "db:seed": "prisma db seed",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset",
    "setup": "docker compose up -d && npm install && npx prisma migrate deploy && npx prisma db seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n NEXT,ELECTRON -c blue,green \"npm run dev\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "CSC_IDENTITY_AUTO_DISCOVERY=false next build && CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --mac"
  },
  "dependencies": {
    "@deck.gl/aggregation-layers": "^9.2.10",
    "@deck.gl/layers": "^9.2.10",
    "@deck.gl/react": "^9.2.10",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.11.2",
    "@scalar/nextjs-api-reference": "^0.10.2",
    "@supabase/supabase-js": "^2.98.0",
    "@tanstack/react-query": "^5.90.21",
    "@vercel/analytics": "^1.6.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "deck.gl": "^9.2.10",
    "dotenv": "^17.3.1",
    "flag-icons": "^7.5.0",
    "leaflet": "^1.9.4",
    "lightweight-charts": "^5.1.0",
    "lucide-react": "^0.575.0",
    "maplibre-gl": "^5.19.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "posthog-js": "^1.359.1",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-day-picker": "^9.14.0",
    "react-dom": "19.2.3",
    "react-grid-layout": "^2.2.2",
    "react-leaflet": "^5.0.0",
    "react-map-gl": "^8.1.0",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.7.0",
    "react-tweet": "^3.3.0",
    "rss-parser": "^3.13.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/pg": "^8.18.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-grid-layout": "^1.3.6",
    "concurrently": "^9.2.1",
    "electron": "^40.6.1",
    "electron-builder": "^25.1.8",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "prisma": "^7.4.2",
    "shadcn": "^3.8.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "prisma": {
    "seed": "tsx --tsconfig tsconfig.json prisma/seed.ts"
  },
  "main": "electron/main.js",
  "build": {
    "appId": "ai.pharos.intel",
    "productName": "Pharos",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": ".next/standalone",
        "to": "standalone",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": ".next/static",
        "to": "standalone/.next/static"
      },
      {
        "from": "public",
        "to": "standalone/public"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "zip",
          "arch": "arm64"
        },
        {
          "target": "dir",
          "arch": "arm64"
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null
    }
  }
}
