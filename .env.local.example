# ─── App ────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8100/api/news
NEXT_PUBLIC_CHAT_API_URL=http://localhost:8100/api/chat
NEXT_PUBLIC_CONFLICT_ID="iran-2026"

# ─── Supabase ───────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_xxx"
SUPABASE_SERVICE_ROLE_KEY="sb_service_role_xxx"

# ─── Database ───────────────────────────────────────────────────
#
# Option A — Local Docker (recommended, used by `npm run setup`)
#   Uses the PostgreSQL container from docker-compose.yml.
#   DATABASE_URL="postgresql://pharos:pharos@localhost:5434/pharos"
#   DATABASE_URL_MIGRATION="postgresql://pharos:pharos@localhost:5434/pharos"
#
# Option B — Supabase Cloud (no Docker required)
#   1. Create a free project at https://supabase.com
#   2. Go to Connect > ORMs > Prisma and copy the pooler URLs.
#   3. Replace <password> and <region> below with your values.
#
#   NOTE: Supabase direct connections (db.*.supabase.co:5432) use
#   IPv6 only, which may fail on networks without IPv6 support.
#   Always use the IPv4 connection pooler URLs shown below.
#
#   Transaction pooler (port 6543) — used by the app at runtime.
#   Session pooler (port 5432) — required for migrations (prisma
#   migrate deploy) because PgBouncer transaction mode does not
#   support advisory locks.
#
DATABASE_URL="postgresql://postgres.project-ref:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DATABASE_URL_MIGRATION="postgresql://postgres.project-ref:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=require"

# ─── X AI (Grok) — tweet verification and X post discovery ─────
XAI_API_KEY="xai-xxx"
XAI_MODEL="grok-4-1-fast-reasoning"

# ─── PostHog analytics ─────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
